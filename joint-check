<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>關節使用小記錄</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #f7f9fb;
      margin: 0;
      padding: 20px;
      color: #333;
    }
    .container {
      max-width: 420px;
      margin: auto;
      background: #fff;
      border-radius: 12px;
      padding: 20px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
    h1 {
      font-size: 20px;
      text-align: center;
    }
    .question {
      margin-top: 20px;
    }
    .option {
      display: block;
      margin: 8px 0;
    }
    button {
      width: 100%;
      padding: 12px;
      background: #4a90e2;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      margin-top: 20px;
    }
    .result {
      margin-top: 20px;
      background: #f0f4f8;
      padding: 12px;
      border-radius: 8px;
    }
    .small {
      font-size: 12px;
      color: #666;
      margin-top: 10px;
      text-align: center;
    }
    .divider {
      margin: 16px 0;
      border-top: 1px dashed #ccc;
    }
  </style>
</head>
<body>

<div class="container" id="formPage">
  <h1>關節使用小記錄</h1>
  <p class="small">花 30 秒記錄自己的感覺（不是檢查）</p>

  <div class="question">
    <strong>1. 最近關節活動感覺？</strong>
    <label class="option"><input type="radio" name="q1" value="比之前順"> 比之前順</label>
    <label class="option"><input type="radio" name="q1" value="差不多"> 差不多</label>
    <label class="option"><input type="radio" name="q1" value="比之前卡"> 比之前卡</label>
  </div>

  <div class="question">
    <strong>2. 日常活動（走路、上下樓）？</strong>
    <label class="option"><input type="radio" name="q2" value="輕鬆一些"> 輕鬆一些</label>
    <label class="option"><input type="radio" name="q2" value="差不多"> 差不多</label>
    <label class="option"><input type="radio" name="q2" value="沒什麼差別"> 沒什麼差別</label>
  </div>

  <div class="question">
    <strong>3. 整體感覺？</strong>
    <label class="option"><input type="radio" name="q3" value="慢慢變好"> 慢慢變好</label>
    <label class="option"><input type="radio" name="q3" value="沒什麼變化"> 沒什麼變化</label>
    <label class="option"><input type="radio" name="q3" value="不太適合我"> 不太適合我</label>
  </div>

  <button onclick="submitForm()">完成記錄</button>
</div>

<div class="container" id="resultPage" style="display:none;">
  <h1>已記錄完成</h1>

  <div id="lastResult"></div>

  <div class="divider"></div>

  <div class="result">
    <strong>你這次的記錄：</strong>
    <p id="currentResult"></p>
  </div>

  <p class="small">📷 建議截圖保存，下次可自己對照</p>
  <p class="small">這不是醫療檢查，只是給你自己參考的小記錄</p>
</div>

<script>
  function submitForm() {
    const q1 = document.querySelector('input[name="q1"]:checked');
    const q2 = document.querySelector('input[name="q2"]:checked');
    const q3 = document.querySelector('input[name="q3"]:checked');

    if (!q1 || !q2 || !q3) {
      alert("請完成所有問題");
      return;
    }

    const current = {
      q1: q1.value,
      q2: q2.value,
      q3: q3.value,
      time: new Date().toLocaleDateString()
    };

    const last = JSON.parse(localStorage.getItem("jointLast"));

    let lastHtml = "";
    if (last) {
      lastHtml = `
        <div class="result">
          <strong>上一次記錄（${last.time}）：</strong>
          <p>活動感覺：${last.q1}<br>
          日常活動：${last.q2}<br>
          整體感覺：${last.q3}</p>
        </div>`;
    }

    document.getElementById("lastResult").innerHTML = lastHtml;
    document.getElementById("currentResult").innerHTML =
      `活動感覺：${current.q1}<br>
       日常活動：${current.q2}<br>
       整體感覺：${current.q3}`;

    localStorage.setItem("jointLast", JSON.stringify(current));

    document.getElementById("formPage").style.display = "none";
    document.getElementById("resultPage").style.display = "block";
  }
</script>

</body>
</html>
